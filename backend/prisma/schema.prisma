// WMS Lite 数据模型
// 数据库：SQLite（开发环境）
// ORM：Prisma
//
// 主键策略：自然键（业务编码）
//   Product 以 sku 为主键，Warehouse 以 code 为主键
//   Inventory 和 TransactionLog 的外键直接引用业务编码，无需内部 ID 中转

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 枚举（SQLite 不支持 enum，用 String 模拟，在代码层约束） ====================

// 用户角色
// ADMIN  - 管理员，拥有所有权限
// STAFF  - 仓库人员，仅可操作入库/出库/库存查询
// model User.role: String

// 流水类型
// IN         - 采购入库
// OUT        - 销售出库
// RETURN_IN  - 销售退货（库存增加）
// RETURN_OUT - 采购退货（库存减少）
// model TransactionLog.type: String

// ==================== 模型 ====================

/// 用户表 — 认证与权限
model User {
  id             Int              @id @default(autoincrement())
  username       String           @unique
  password       String                          // bcrypt 哈希存储
  name           String                          // 显示名称
  role           String           @default("STAFF")  // ADMIN | STAFF
  operatorLogs   TransactionLog[]               // 该用户操作过的所有流水
  createdAt      DateTime         @default(now())
}

/// 商品表 — sku 即主键，扫码/输入编码直接定位商品
model Product {
  sku          String           @id             // 商品编码（即主键）
  name         String
  spec         String?                         // 规格描述（可选）
  inventory    Inventory[]
  transactions TransactionLog[]                // 该商品的所有流水
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

/// 仓库表 — code 即主键，编码直接定位仓库
model Warehouse {
  code         String           @id             // 仓库编码（即主键）
  name         String
  address      String?                         // 仓库地址（可选）
  inventory    Inventory[]
  transactions TransactionLog[]                // 该仓库的所有流水
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

/// 库存表 — 商品 sku + 仓库 code 联合唯一，记录可用库存数量
model Inventory {
  id             Int              @id @default(autoincrement())
  sku            String
  warehouseCode  String
  quantity       Int              @default(0)   // 可用库存
  product        Product          @relation(fields: [sku], references: [sku])
  warehouse      Warehouse        @relation(fields: [warehouseCode], references: [code])

  @@unique([sku, warehouseCode])   // 同一商品在同一仓库只有一条库存记录
}

/// 流水记录表 — 所有出入库操作的审计日志
model TransactionLog {
  id            Int        @id @default(autoincrement())
  bizNo         String     @unique       // 业务单号（UUID），幂等性保证，防止重复提交
  sku           String                   // 商品编码（直接引用 Product.sku）
  warehouseCode String                   // 仓库编码（直接引用 Warehouse.code）
  type          String                   // IN | OUT | RETURN_IN | RETURN_OUT
  quantity      Int                      // 操作数量（始终为正数）
  operatorId    Int                      // 操作人 ID（关联 User）
  remark        String?                  // 备注（退货原因等）
  product       Product    @relation(fields: [sku], references: [sku])
  warehouse     Warehouse  @relation(fields: [warehouseCode], references: [code])
  operator      User       @relation(fields: [operatorId], references: [id])
  createdAt     DateTime   @default(now())

  @@index([sku, warehouseCode])    // 按商品+仓库查询流水
  @@index([createdAt])             // 按时间范围查询流水
}
